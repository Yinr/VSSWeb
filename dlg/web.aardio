import win.ui;
import win.dlg.message;
import config;
import fsys.version;
import logger;

/*DSG{{*/
var winform = win.form(text="监控 - 用户名：admin";right=1280;bottom=750)
winform.add()
/*}}*/

import web.form;
web.form.emulation(11001);

config.loadDevice();
config.loadLog();
logger.init(null);
logger.configure(config.log.level, config.log.fileEnabled);

var username = config.device.username;
if(username === null || username == "") {
    username = "admin";
}

var verInfo = fsys.version.getInfo(io._exepath);
var currentVersion = verInfo ? tostring(verInfo.productVersion) : "";
winform.text = "监控 Web 版" ++ (currentVersion != "" ? " v" ++ currentVersion : "") ++ " - 用户名：" ++ username;

var ip = config.device.ip;
if(ip === null || ip == "") {
    ip = "192.168.0.5";
    config.device.ip = ip;
    config.saveDevice();
}

var wb = web.form(winform);
wb.silent = true;

logger.info("打开 Web 版页面 ip=" ++ ip);
wb.go("http://" ++ ip);

winform.center();

if(owner !== null) {
    return winform;
}

winform.show();

return win.loopMessage();
