// 日志初始化
logger.init(null);

log = function(msg){
    logger.info(msg);
}

var cfg = {
    ip = "";
    username = "";
    password = "";
}

var wb = null;
var webDlg = null;
var wbReady = false;
var wbLoading = false;
var wbLoadToken = 0;
var networkChecking = false;
var isLoggedIn = false;
var pendingAutoOpenAll = false;
var useCodebaseForActiveX = false;
var lastActiveXCheckResult = null;
var lastNetworkCheckResult = null;

var chButtons = {};
var chOpened = {};
var chNames = {};
var currentWid = null;
var winMap = {};
var winState = {};



setStatus = function(msg){
    logger.status(msg);

    var s = "状态：" ++ msg;

    if(currentWid !== null) {
        s = s ++ '\r\n当前窗口：' ++ tostring(currentWid);

        var key = "w" ++ tostring(currentWid);
        var cid = winMap[key];

        if(cid !== null && cid >= 0) {
            s = s ++ " / 通道 " ++ string.format("%02d", cid + 1);
        }
        else {
            s = s ++ " / 空";
        }
    }

    mainForm.statusText.text = s;
}

loadConfig = function(){
    config.loadDevice();
    config.loadLog();

    cfg.ip = config.device.ip;
    if(cfg.ip === null || cfg.ip == "") {
        cfg.ip = "192.168.0.5";
    }

    cfg.username = config.device.username;
    if(cfg.username === null || cfg.username == "") {
        cfg.username = "admin";
    }

    cfg.password = config.device.password;
    if(cfg.password === null) {
        cfg.password = "";
    }

    logger.configure(config.log.level, config.log.fileEnabled);
}

saveConfig = function(){
    config.device.ip = cfg.ip;
    config.device.username = cfg.username;
    config.device.password = cfg.password;

    config.saveDevice();
    logger.debug("连接配置已保存");
}
hasFullConfig = function(){
    if(cfg.ip === null || cfg.ip == "") return false;
    if(cfg.username === null || cfg.username == "") return false;
    if(cfg.password === null || cfg.password == "") return false;

    return true;
}

onNetworkCheckResult = function(ret, autoConnect){
    networkChecking = false;
    lastNetworkCheckResult = ret;

    if(ret === null) {
        pendingAutoOpenAll = false;
        isLoggedIn = false;
        logger.error("设备网络检测返回空结果");
        setStatus("设备网络检测失败");
        return;
    }

    if(ret.mode !== null) {
        logger.ret("networkCheck.mode=" ++ tostring(ret.mode));
    }

    if(ret.pingOk !== null) {
        logger.ret("ping " ++ ret.host ++ "=" ++ tostring(ret.pingOk));
    }

    if(ret.pageChecked) {
        logger.ret("http.ivsWeb=" ++ tostring(ret.pageOk));

        if(ret.pageInfo !== null) {
            logger.ret("http.strongHits=" ++ tostring(ret.pageInfo.strongHits));
            logger.ret("http.weakHits=" ++ tostring(ret.pageInfo.weakHits));
        }
    }

    if(ret.clearlyUnreachable) {
        pendingAutoOpenAll = false;
        isLoggedIn = false;
        logger.error(ret.message);
        setStatus(ret.message);
        return;
    }

    if(!ret.ok) {
        logger.error(ret.message ++ "，继续尝试 ActiveX 登录");
        setStatus(ret.message ++ "，继续尝试连接");
    }

    if(!wbReady) {
        loadMiniHtml(autoConnect);
        return;
    }

    if(autoConnect) {
        loginDevice(true);
    }
}

mainForm.onNetworkCheckResult = onNetworkCheckResult;

checkDeviceNetworkAsync = function(autoConnect){
    config.loadNetworkCheck();
    logger.debug("开始设备网络预检 mode=" ++ tostring(config.networkCheck.mode) ++ " autoConnect=" ++ tostring(autoConnect));

    if(config.networkCheck.skip) {
        logger.info("已跳过设备网络预检");
        setStatus("已跳过设备网络预检，正在加载 ActiveX");

        if(!wbReady) {
            loadMiniHtml(autoConnect);
            return;
        }

        if(autoConnect) {
            loginDevice(true);
        }

        return;
    }

    if(networkChecking) {
        if(autoConnect) {
            pendingAutoOpenAll = true;
        }

        setStatus("正在检测设备网络：" ++ cfg.ip);
        return;
    }

    networkChecking = true;
    lastNetworkCheckResult = null;
    setStatus("正在检测设备网络：" ++ cfg.ip);

    var hwnd = mainForm.hwnd;
    var host = cfg.ip;
    var mode = config.networkCheck.mode;

    thread.invoke(
        function(hwnd, host, autoConnect, mode){
            import netcheck;
            import thread;

            var ret = netcheck.checkDevice(host, mode);
            thread.callWnd(hwnd, "onNetworkCheckResult", ret, autoConnect);
        },
        hwnd, host, autoConnect, mode
    );
}

clearWindowMapByChannel = function(chId){
    for(w=0;15;1){
        var key = "w" ++ tostring(w);

        if(winMap[key] === chId) {
            winMap[key] = -1;
            winState[key] = false;
        }
    }
}

callJs = function(funcName, a, b){
    if(wb === null) {
        logger.error("浏览器控件尚未创建，无法调用 JS：" ++ funcName);
        setStatus("浏览器控件尚未创建");
        return null;
    }

    var script = "";

    if(funcName == "checkActiveX") {
        script = "checkActiveX();";
    }
    elseif(funcName == "loginFromExternal") {
        script = "loginFromExternal();";
    }
    elseif(funcName == "openAll") {
        script = "openAll();";
    }
    elseif(funcName == "closeAll") {
        script = "closeAll();";
    }
    elseif(funcName == "openChannel") {
        script = "openChannel(" ++ tostring(a) ++ ");";
    }
    elseif(funcName == "closeChannel") {
        script = "closeChannel(" ++ tostring(a) ++ ");";
    }
    elseif(funcName == "ptz") {
        script = "ptz(" ++ tostring(a) ++ "," ++ tostring(b) ++ ");";
    }
    elseif(funcName == "showDeviceConfig") {
        script = "showDeviceConfig();";
    }
    elseif(funcName == "showPlayback") {
        script = "showPlayback();";
    }
    elseif(funcName == "showAlarm") {
        script = "showAlarm();";
    }
    elseif(funcName == "showAbout") {
        script = "showAbout();";
    }
    elseif(funcName == "logoutDevice") {
        script = "logoutDevice();";
    }
    else {
        logger.error("未知 JS 函数：" ++ funcName);
        return null;
    }

    try {
        logger.debug("[SCRIPT] " ++ script);
        return wb.doScript(script);
    }
    catch(e) {
        logger.error("doScript 调用失败：" ++ funcName ++ " / " ++ tostring(e));
        setStatus("调用 JS 失败：" ++ funcName);
        return null;
    }
}

