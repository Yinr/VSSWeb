*/;

    html = string.replace(html, "__BASE_URL__", baseUrl);
    return html;
}

setupExternal = function(){
    wb.external = {
        GetIp = function(){
            return cfg.ip;
        };

        GetUsername = function(){
            return cfg.username;
        };

        GetPassword = function(){
            return cfg.password;
        };

        Log = function(msg){
            logger.js(tostring(msg));
        };

        LoginResult = function(ret){
            logger.callback("LoginResult=" ++ tostring(ret));

            if(!!ret) {
                isLoggedIn = true;
                setStatus("登录成功：" ++ cfg.ip);

                if(pendingAutoOpenAll) {
                    pendingAutoOpenAll = false;

                    mainForm.setTimeout(
                        function(){
                            openAllChannels();
                        },
                        1000
                    );
                }
            }
            else {
                isLoggedIn = false;
                pendingAutoOpenAll = false;
                setStatus("登录失败：ActiveX 返回 " ++ tostring(ret));
            }
        };

        OpenAllResult = function(ret){
            logger.callback("OpenAllResult=" ++ tostring(ret));

            if(!!ret) {
                setStatus("已请求打开全部通道");
            }
            else {
                setStatus("打开全部通道失败：" ++ tostring(ret));
            }
        };

        CloseAllResult = function(ret){
            logger.callback("CloseAllResult=" ++ tostring(ret));

            if(!!ret) {
                channel.clearAllState(chOpened, chButtons, chNames);
                currentWid = null;
                winMap = {};
                winState = {};
                setStatus("已请求关闭全部通道");
            }
            else {
                setStatus("关闭全部通道失败：" ++ tostring(ret));
            }
        };

        StateChanged = function(ci, ps, wid){
            logger.event(
                "StateChanged"
                ++ " ci=" ++ tostring(ci)
                ++ " ch=" ++ (ci >= 0 && ci <= 7 ? string.format("%02d", ci + 1) : "-")
                ++ " ps=" ++ tostring(ps)
                ++ " wid=" ++ tostring(wid)
            );

            if(ci == -1 || ci == 32) {
                if(ps == 3 || ps == 5) {
                    setStatus("当前窗口进入回放/播放控制状态 ps=" ++ tostring(ps));
                }
                else {
                    setStatus("特殊播放状态 ci=" ++ tostring(ci) ++ " ps=" ++ tostring(ps));
                }

                return;
            }

            if(ci >= 0 && ci <= 7) {
                if(ps == 1 || ps == 2) {
                    chOpened[ci + 1] = true;
                    channel.setButtonText(chButtons, ci, true, chNames);
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 正在播放 ps=" ++ tostring(ps));
                }
                elseif(ps == 0) {
                    chOpened[ci + 1] = false;
                    channel.setButtonText(chButtons, ci, false, chNames);
                    clearWindowMapByChannel(ci);
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 已关闭");
                }
                elseif(ps == 3) {
                    chOpened[ci + 1] = false;
                    channel.setButtonText(chButtons, ci, false, chNames);
                    clearWindowMapByChannel(ci);
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 进入非实时预览状态 ps=3，已重置按钮");
                }
                else {
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 未处理状态 ps=" ++ tostring(ps));
                }
            }
            else {
                setStatus("通道状态变化 ci=" ++ tostring(ci) ++ " ps=" ++ tostring(ps));
            }
        };

        ReturnWindInfo = function(wid, cid, ps, sit){
            logger.event(
                "ReturnWindInfo"
                ++ " wid=" ++ tostring(wid)
                ++ " cid=" ++ tostring(cid)
                ++ " ch=" ++ (cid >= 0 && cid <= 7 ? string.format("%02d", cid + 1) : "-")
                ++ " ps=" ++ tostring(ps)
                ++ " sit=" ++ tostring(sit)
            );

            currentWid = wid;

            if(wid !== null) {
                var key = "w" ++ tostring(wid);

                if(ps == 1 || ps == 2) {
                    winMap[key] = cid;
                    winState[key] = ps;
                }
                elseif(ps == 0) {
                    winMap[key] = -1;
                    winState[key] = ps;
                }
                elseif(ps == 4 || ps == 5) {
                    winState[key] = ps;
                }
                else {
                    winMap[key] = cid;
                    winState[key] = ps;
                }
            }

            if(ps == 4 || ps == 5) {
                setStatus("当前窗口处于录像/回放状态 ps=" ++ tostring(ps));
            }
            else {
                setStatus(
                    "窗口信息 wid=" ++ tostring(wid)
                    ++ " cid=" ++ tostring(cid)
                    ++ " ps=" ++ tostring(ps)
                );
            }
        };

        DeviceDisconnected = function(ip, pt){
            logger.event("DeviceDisconnected ip=" ++ tostring(ip) ++ " pt=" ++ tostring(pt));

            isLoggedIn = false;
            channel.clearAllState(chOpened, chButtons, chNames);
            currentWid = null;
            winMap = {};
            winState = {};
            setStatus("设备断开：" ++ tostring(ip));
        };

        DeviceChanged = function(strDevIp, lPort, lType){
            logger.event(
                "DeviceChanged"
                ++ " ip=" ++ tostring(strDevIp)
                ++ " port=" ++ tostring(lPort)
                ++ " type=" ++ tostring(lType)
            );

            setStatus(
                "设备变化 ip=" ++ tostring(strDevIp)
                ++ " port=" ++ tostring(lPort)
                ++ " type=" ++ tostring(lType)
            );
        };
    }
}

loadMiniHtml = function(autoConnect){
    loadConfig();
    channel.loadNames(chNames);

    wbReady = false;
    isLoggedIn = false;
    pendingAutoOpenAll = false;
    currentWid = null;
    winMap = {};
    winState = {};
    channel.clearAllState(chOpened, chButtons, chNames);

    logger.clear();

    log("==============================================");
    log("监控程序启动");
    log("配置文件：" ++ config.path);
    log("日志文件：" ++ logger.path);
    log("ip=" ++ cfg.ip);
    log("username=" ++ cfg.username);
    log("password=" ++ (cfg.password == "" ? "<空>" : "<已设置>"));
    log("==============================================");

    if(wb === null) {
        wb = web.form(mainForm.videoHost);
        wb.silent = true;
        setupExternal();
    }

    wb.write(makeHtml());
    setStatus("已加载 ActiveX，默认 4 窗格");

    mainForm.setTimeout(
        function(){
            wbReady = true;
            setStatus("ActiveX 已准备好");

            logger.call("JS ping()");
            var pingRet = callJs("ping");
            logger.ret("ping=" ++ tostring(pingRet));

            if(autoConnect) {
                autoLoginAndOpenAll();
            }
        },
        2000
    );
}

loginDevice = function(){
    loadConfig();

    if(!wbReady) {
        setStatus("ActiveX 尚未准备好");
        return false;
    }

    if(!hasFullConfig()) {
        setStatus("未设置完整连接信息，请点击“设置”");
        return false;
    }

    setStatus("正在连接：" ++ cfg.ip);

    logger.call("JS loginFromExternal()");
    var r = callJs("loginFromExternal");
    logger.ret("loginFromExternal=" ++ tostring(r));

    return true;
}

autoLoginAndOpenAll = function(){
    pendingAutoOpenAll = true;
    loginDevice();
}

logoutDevice = function(){
    logger.call("JS logoutDevice()");

    try {
        var r = callJs("logoutDevice");
        logger.ret("logoutDevice=" ++ tostring(r));
    }
    catch(e) {
    }

    isLoggedIn = false;
    pendingAutoOpenAll = false;
    channel.clearAllState(chOpened, chButtons, chNames);
    currentWid = null;
    winMap = {};
    winState = {};
    setStatus("已断开");
}

openAllChannels = function(){
    if(!wbReady) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    if(!isLoggedIn) {
        pendingAutoOpenAll = true;
        loginDevice();
        return;
    }

    logger.call("JS openAll()");
    var r = callJs("openAll");
    logger.ret("openAll=" ++ tostring(r));
}

closeAllChannels = function(){
    if(!wbReady) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    logger.call("JS closeAll()");
    var r = callJs("closeAll");
    logger.ret("closeAll=" ++ tostring(r));
}

openChannel = function(chId){
    if(!wbReady) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    if(!isLoggedIn) {
        pendingAutoOpenAll = false;
        loginDevice();
        return;
    }

    logger.call("JS openChannel(" ++ tostring(chId) ++ ")");
    var r = callJs("openChannel", chId);
    logger.ret("openChannel=" ++ tostring(r));

    setStatus("已请求打开通道 " ++ string.format("%02d", chId + 1));
}

closeChannel = function(chId){
    if(!wbReady) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    logger.call("JS closeChannel(" ++ tostring(chId) ++ ")");
    var r = callJs("closeChannel", chId);
    logger.ret("closeChannel=" ++ tostring(r));

    if(!!r) {
        setStatus("已请求关闭通道 " ++ string.format("%02d", chId + 1));
    }
    else {
        chOpened[chId + 1] = false;
        channel.setButtonText(chButtons, chId, false, chNames);
        clearWindowMapByChannel(chId);

        setStatus("通道 " ++ string.format("%02d", chId + 1) ++ " 关闭失败，已按原网页状态模型重置按钮");
    }
}

toggleChannel = function(chId){
    var idx = chId + 1;

    if(chOpened[idx]) {
        closeChannel(chId);
    }
    else {
        openChannel(chId);
    }
}

ptz = function(cmd, stop){
    if(!wbReady) return;

    logger.call("JS ptz(" ++ tostring(cmd) ++ "," ++ tostring(stop) ++ ")");
    var r = callJs("ptz", cmd, stop);
    logger.ret("ptz=" ++ tostring(r));
}

activeXMenu = function(funcName, label, needLogin){
    if(!wbReady) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    if(needLogin && !isLoggedIn) {
        setStatus(label ++ "需要先连接设备");
        pendingAutoOpenAll = false;
        loginDevice();
        return;
    }

    logger.call("JS " ++ funcName ++ "()");
    var r = callJs(funcName);
    logger.ret(funcName ++ "=" ++ tostring(r));

    setStatus("已打开：" ++ label);
}

showSettingDialog = function(){
    var re = mainForm.loadForm("\dlg\setting.aardio").doModal();
    if(re == 1) {
        loadConfig();
        if(hasFullConfig()) {
            logoutDevice();
            mainForm.setTimeout(
                function(){
                    loadMiniHtml(true);
                },
                500
            );
        }
    }
}

openWebVersion = function(){
    webDlg = mainForm.loadForm("\dlg\web.aardio");
    webDlg.show();
}

openDeviceInBrowser = function(){
    loadConfig();

    var ip = cfg.ip;
    if(ip === null || ip == "") {
        ip = "192.168.0.5";
    }

    process.execute("http://" ++ ip);
}

// 初始化通道按钮数组
chButtons = {
    mainForm.btnCh01;
    mainForm.btnCh02;
    mainForm.btnCh03;
    mainForm.btnCh04;
    mainForm.btnCh05;
    mainForm.btnCh06;
    mainForm.btnCh07;
    mainForm.btnCh08;
}

loadConfig();
channel.loadNames(chNames);

for(i=1;8;1){
    chOpened[i] = false;
    channel.setButtonText(chButtons, i - 1, false, chNames);
}

// 事件绑定
mainForm.btnSetting.oncommand = function(){
    showSettingDialog();
}

mainForm.btnLogin.oncommand = function(){
    autoLoginAndOpenAll();
}

mainForm.btnLogout.oncommand = function(){
    logoutDevice();
}

mainForm.btnOpenAll.oncommand = function(){
    openAllChannels();
}

mainForm.btnCloseAll.oncommand = function(){
    closeAllChannels();
}

mainForm.btnSysConfig.oncommand = function(){
    activeXMenu("showDeviceConfig", "系统设置", 1);
}

mainForm.btnPlayback.oncommand = function(){
    activeXMenu("showPlayback", "录像查询", 1);
}

mainForm.btnAlarm.oncommand = function(){
    activeXMenu("showAlarm", "警报设置", 1);
}

mainForm.btnAbout.oncommand = function(){
    activeXMenu("showAbout", "关于", 0);
}

mainForm.btnWeb.oncommand = function(){
    openWebVersion();
}

mainForm.btnBrowser.oncommand = function(){
    openDeviceInBrowser();
}

mainForm.btnCh01.oncommand = function(){ toggleChannel(0); }
mainForm.btnCh02.oncommand = function(){ toggleChannel(1); }
mainForm.btnCh03.oncommand = function(){ toggleChannel(2); }
mainForm.btnCh04.oncommand = function(){ toggleChannel(3); }
mainForm.btnCh05.oncommand = function(){ toggleChannel(4); }
mainForm.btnCh06.oncommand = function(){ toggleChannel(5); }
mainForm.btnCh07.oncommand = function(){ toggleChannel(6); }
mainForm.btnCh08.oncommand = function(){ toggleChannel(7); }

mainForm.btnUp.onMouseDown = function(){ ptz(0, 0); }
mainForm.btnUp.onMouseUp = function(){ ptz(0, 1); }

mainForm.btnDown.onMouseDown = function(){ ptz(1, 0); }
mainForm.btnDown.onMouseUp = function(){ ptz(1, 1); }

mainForm.btnLeft.onMouseDown = function(){ ptz(2, 0); }
mainForm.btnLeft.onMouseUp = function(){ ptz(2, 1); }

mainForm.btnRight.onMouseDown = function(){ ptz(3, 0); }
mainForm.btnRight.onMouseUp = function(){ ptz(3, 1); }

mainForm.onClose = function(){
    logoutDevice();
}

mainForm.center();
mainForm.show();

mainForm.setTimeout(
    function(){
        if(hasFullConfig()) {
            loadMiniHtml(true);
        }
        else {
            loadMiniHtml(false);
            setStatus("未设置密码，请点击“设置”");
        }
    },
    500
);

return win.loopMessage();
