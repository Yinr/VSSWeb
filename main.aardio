resetRuntimeState = function(clearPendingAutoOpenAll){
    if(clearPendingAutoOpenAll) {
        pendingAutoOpenAll = false;
    }

    isLoggedIn = false;
    currentWid = null;
    winMap = {};
    winState = {};
    channel.clearAllState(chOpened, chButtons, chNames);
}

finishActiveXLoad = function(autoConnect, checkRet){
    wbLoading = false;

    if(!checkRet) {
        wbReady = false;
        pendingAutoOpenAll = false;
        logger.error("ActiveX 检测失败");
        setStatus("无法加载 ActiveX，请点击“打开 Web 版”或“打开浏览器”安装控件");
        win.msgbox('无法加载 IVSWeb ActiveX 控件。\n\n请确认本机已安装并注册控件，或点击主界面的“打开 Web 版”“打开浏览器”从设备页面安装/访问。', "ActiveX 加载失败", "warning", mainForm);
        return;
    }

    wbReady = true;
    logger.info("ActiveX 检测成功，控件已就绪");
    setStatus("ActiveX 已准备好，默认 4 窗格");

    if(autoConnect || pendingAutoOpenAll) {
        loginDevice(true);
    }
}

checkActiveXReady = function(autoConnect, retriesLeft, loadToken){
    if(loadToken !== null && loadToken != wbLoadToken) {
        logger.debug("忽略已失效的 ActiveX 检测 token=" ++ tostring(loadToken));
        return;
    }

    lastActiveXCheckResult = null;

    logger.call("JS checkActiveX()");
    var checkRet = callJs("checkActiveX");
    logger.ret("checkActiveX=" ++ tostring(checkRet));

    if(lastActiveXCheckResult === null && checkRet !== null) {
        lastActiveXCheckResult = !!checkRet;
    }

    if(!!lastActiveXCheckResult) {
        finishActiveXLoad(autoConnect, true);
        return;
    }

    if(retriesLeft > 0) {
        setStatus("ActiveX 正在初始化，继续等待");
        mainForm.setTimeout(
            function(){
                checkActiveXReady(autoConnect, retriesLeft - 1, loadToken);
            },
            1000
        );
        return;
    }

    finishActiveXLoad(autoConnect, false);
}

setupExternal = function(){
    wb.external = {
        GetIp = function(){
            return cfg.ip;
        };

        GetUsername = function(){
            return cfg.username;
        };

        GetPassword = function(){
            return cfg.password;
        };

        Log = function(msg){
            logger.js(tostring(msg));
        };

        ActiveXCheckResult = function(ret){
            lastActiveXCheckResult = !!ret;
        };

        LoginResult = function(ret){
            logger.callback("LoginResult=" ++ tostring(ret));

            if(!!ret) {
                isLoggedIn = true;
                logger.info("设备登录成功 ip=" ++ cfg.ip);
                setStatus("登录成功：" ++ cfg.ip);

                if(pendingAutoOpenAll) {
                    pendingAutoOpenAll = false;

                    mainForm.setTimeout(
                        function(){
                            openAllChannels();
                        },
                        1000
                    );
                }
            }
            else {
                isLoggedIn = false;
                pendingAutoOpenAll = false;
                logger.error("设备登录失败 ip=" ++ cfg.ip ++ " ret=" ++ tostring(ret));

                if(lastNetworkCheckResult && !lastNetworkCheckResult.ok) {
                    setStatus(lastNetworkCheckResult.message);
                }
                else {
                    setStatus("登录失败：ActiveX 返回 " ++ tostring(ret));
                }
            }
        };

        OpenAllResult = function(ret){
            logger.callback("OpenAllResult=" ++ tostring(ret));

            if(!!ret) {
                logger.info("已请求打开全部通道");
                setStatus("已请求打开全部通道");
            }
            else {
                logger.error("打开全部通道失败 ret=" ++ tostring(ret));
                setStatus("打开全部通道失败：" ++ tostring(ret));
            }
        };

        CloseAllResult = function(ret){
            logger.callback("CloseAllResult=" ++ tostring(ret));

            if(!!ret) {
                resetRuntimeState(false);
                logger.info("已请求关闭全部通道");
                setStatus("已请求关闭全部通道");
            }
            else {
                logger.error("关闭全部通道失败 ret=" ++ tostring(ret));
                setStatus("关闭全部通道失败：" ++ tostring(ret));
            }
        };

        StateChanged = function(ci, ps, wid){
            logger.event(
                "StateChanged"
                ++ " ci=" ++ tostring(ci)
                ++ " ch=" ++ (ci >= 0 && ci <= 7 ? string.format("%02d", ci + 1) : "-")
                ++ " ps=" ++ tostring(ps)
                ++ " wid=" ++ tostring(wid)
            );

            if(ci == -1 || ci == 32) {
                if(ps == 3 || ps == 5) {
                    setStatus("当前窗口进入回放/播放控制状态 ps=" ++ tostring(ps));
                }
                else {
                    setStatus("特殊播放状态 ci=" ++ tostring(ci) ++ " ps=" ++ tostring(ps));
                }

                return;
            }

            if(ci >= 0 && ci <= 7) {
                if(ps == 1 || ps == 2) {
                    chOpened[ci + 1] = true;
                    channel.setButtonText(chButtons, ci, true, chNames);
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 正在播放 ps=" ++ tostring(ps));
                }
                elseif(ps == 0) {
                    chOpened[ci + 1] = false;
                    channel.setButtonText(chButtons, ci, false, chNames);
                    clearWindowMapByChannel(ci);
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 已关闭");
                }
                elseif(ps == 3) {
                    chOpened[ci + 1] = false;
                    channel.setButtonText(chButtons, ci, false, chNames);
                    clearWindowMapByChannel(ci);
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 进入非实时预览状态 ps=3，已重置按钮");
                }
                else {
                    setStatus("通道 " ++ string.format("%02d", ci + 1) ++ " 未处理状态 ps=" ++ tostring(ps));
                }
            }
            else {
                setStatus("通道状态变化 ci=" ++ tostring(ci) ++ " ps=" ++ tostring(ps));
            }
        };

        ReturnWindInfo = function(wid, cid, ps, sit){
            logger.event(
                "ReturnWindInfo"
                ++ " wid=" ++ tostring(wid)
                ++ " cid=" ++ tostring(cid)
                ++ " ch=" ++ (cid >= 0 && cid <= 7 ? string.format("%02d", cid + 1) : "-")
                ++ " ps=" ++ tostring(ps)
                ++ " sit=" ++ tostring(sit)
            );

            currentWid = wid;

            if(wid !== null) {
                var key = "w" ++ tostring(wid);

                if(ps == 1 || ps == 2) {
                    winMap[key] = cid;
                    winState[key] = ps;
                }
                elseif(ps == 0) {
                    winMap[key] = -1;
                    winState[key] = ps;
                }
                elseif(ps == 4 || ps == 5) {
                    winState[key] = ps;
                }
                else {
                    winMap[key] = cid;
                    winState[key] = ps;
                }
            }

            if(ps == 4 || ps == 5) {
                setStatus("当前窗口处于录像/回放状态 ps=" ++ tostring(ps));
            }
            else {
                setStatus(
                    "窗口信息 wid=" ++ tostring(wid)
                    ++ " cid=" ++ tostring(cid)
                    ++ " ps=" ++ tostring(ps)
                );
            }
        };

        DeviceDisconnected = function(ip, pt){
            logger.event("DeviceDisconnected ip=" ++ tostring(ip) ++ " pt=" ++ tostring(pt));

            resetRuntimeState(false);
            setStatus("设备断开：" ++ tostring(ip));
        };

        DeviceChanged = function(strDevIp, lPort, lType){
            logger.event(
                "DeviceChanged"
                ++ " ip=" ++ tostring(strDevIp)
                ++ " port=" ++ tostring(lPort)
                ++ " type=" ++ tostring(lType)
            );

            setStatus(
                "设备变化 ip=" ++ tostring(strDevIp)
                ++ " port=" ++ tostring(lPort)
                ++ " type=" ++ tostring(lType)
            );
        };
    }
}

loadMiniHtml = function(autoConnect){
    if(webDlg !== null) {
        pendingAutoOpenAll = false;
        logger.info("内嵌 Web 版已打开，跳过主界面 ActiveX 加载");
        setStatus("内嵌 Web 版已打开，主界面 ActiveX 暂停加载");
        return;
    }

    if(wbLoading) {
        if(autoConnect) {
            pendingAutoOpenAll = true;
        }

        logger.debug("ActiveX 正在加载，复用当前加载流程");
        setStatus("ActiveX 正在加载，请稍候");
        return;
    }

    wbLoading = true;
    wbLoadToken++;
    var loadToken = wbLoadToken;
    loadConfig();
    channel.loadNames(chNames);

    wbReady = false;
    resetRuntimeState(true);

    logger.clear();

    logger.info("==============================================");
    logger.info("监控程序启动");
    logger.info("配置文件：" ++ config.path);
    logger.info("日志文件：" ++ logger.path ++ " / fileEnabled=" ++ tostring(logger.enableFile));
    logger.info("日志等级：" ++ logger.level);
    logger.debug("ip=" ++ cfg.ip);
    logger.debug("username=" ++ cfg.username);
    logger.debug("password=" ++ (cfg.password == "" ? "<空>" : "<已设置>"));
    logger.debug("useCodebaseForActiveX=" ++ tostring(useCodebaseForActiveX));
    logger.info("==============================================");

    if(wb === null) {
        wb = web.form(mainForm.videoHost);
        wb.silent = true;
        setupExternal();
        logger.info("已创建 WebBrowser 宿主");
    }

    if(autoConnect) {
        pendingAutoOpenAll = true;
    }

    setStatus("正在加载 ActiveX");
    wb.write(makeHtml());
    setStatus("已创建 ActiveX 容器，正在检测控件");

    mainForm.setTimeout(
        function(){
            checkActiveXReady(autoConnect, 4, loadToken);
        },
        2000
    );
}

unloadMainActiveX = function(){
    logger.info("卸载主界面 ActiveX：准备打开内嵌 Web 版");

    if(wb !== null) {
        if(wbReady || wbLoading) {
            logger.call("JS logoutDevice() before unload");

            try {
                var r = callJs("logoutDevice");
                logger.ret("logoutDevice.beforeUnload=" ++ tostring(r));
            }
            catch(e) {
                logger.error("卸载前断开 ActiveX 异常：" ++ tostring(e));
            }
        }

        try {
            wb.write("<html><body style='margin:0;background:#000'></body></html>");
        }
        catch(e) {
            logger.error("卸载 ActiveX 容器失败：" ++ tostring(e));
        }
    }

    wbReady = false;
    wbLoading = false;
    wbLoadToken++;
    lastActiveXCheckResult = null;
    resetRuntimeState(true);
    setStatus("主界面 ActiveX 已卸载");
}

loginDevice = function(skipNetworkCheck){
    loadConfig();

    if(!wbReady) {
        logger.error("ActiveX 尚未准备好，无法登录");
        setStatus("ActiveX 尚未准备好");
        return false;
    }

    if(!hasFullConfig()) {
        logger.error("连接信息不完整，无法登录");
        setStatus("未设置完整连接信息，请点击“设置”");
        return false;
    }

    if(!skipNetworkCheck) {
        checkDeviceNetworkAsync(true);
        return true;
    }

    setStatus("正在连接：" ++ cfg.ip);
    logger.info("开始连接设备 ip=" ++ cfg.ip ++ " skipNetworkCheck=" ++ tostring(skipNetworkCheck));

    logger.call("JS loginFromExternal()");
    var r = callJs("loginFromExternal");
    logger.ret("loginFromExternal=" ++ tostring(r));

    return true;
}

autoLoginAndOpenAll = function(){
    pendingAutoOpenAll = true;

    loadConfig();
    logger.info("请求自动登录并打开全部通道");

    if(!hasFullConfig()) {
        pendingAutoOpenAll = false;
        logger.error("连接信息不完整，无法自动登录");
        setStatus("未设置完整连接信息，请点击“设置”");
        return;
    }

    checkDeviceNetworkAsync(true);
}

logoutDevice = function(){
    logger.info("请求断开设备");
    logger.call("JS logoutDevice()");

    try {
        var r = callJs("logoutDevice");
        logger.ret("logoutDevice=" ++ tostring(r));
    }
    catch(e) {
    }

    resetRuntimeState(true);
    setStatus("已断开");
}

openAllChannels = function(){
    if(!wbReady) {
        logger.info("ActiveX 未就绪，先触发自动登录和打开全部通道");
        autoLoginAndOpenAll();
        return;
    }

    if(!isLoggedIn) {
        pendingAutoOpenAll = true;
        logger.info("尚未登录，先执行登录再打开全部通道");
        loginDevice();
        return;
    }

    logger.call("JS openAll()");
    var r = callJs("openAll");
    logger.ret("openAll=" ++ tostring(r));
}

closeAllChannels = function(){
    if(!wbReady) {
        logger.error("ActiveX 尚未准备好，无法关闭全部通道");
        setStatus("ActiveX 尚未准备好");
        return;
    }

    logger.call("JS closeAll()");
    var r = callJs("closeAll");
    logger.ret("closeAll=" ++ tostring(r));
}

openChannel = function(chId){
    if(!wbReady) {
        logger.info("ActiveX 尚未加载，先加载控件再处理通道请求 ch=" ++ tostring(chId + 1));
        setStatus("ActiveX 尚未加载，正在加载控件，请稍后再打开通道");
        loadMiniHtml(false);
        return;
    }

    if(!isLoggedIn) {
        pendingAutoOpenAll = false;
        logger.info("尚未登录，先执行登录再打开通道 ch=" ++ tostring(chId + 1));
        loginDevice();
        return;
    }

    logger.call("JS openChannel(" ++ tostring(chId) ++ ")");
    var r = callJs("openChannel", chId);
    logger.ret("openChannel=" ++ tostring(r));

    setStatus("已请求打开通道 " ++ string.format("%02d", chId + 1));
}

closeChannel = function(chId){
    if(!wbReady) {
        logger.error("ActiveX 尚未准备好，无法关闭通道 ch=" ++ tostring(chId + 1));
        setStatus("ActiveX 尚未准备好");
        return;
    }

    logger.call("JS closeChannel(" ++ tostring(chId) ++ ")");
    var r = callJs("closeChannel", chId);
    logger.ret("closeChannel=" ++ tostring(r));

    if(!!r) {
        setStatus("已请求关闭通道 " ++ string.format("%02d", chId + 1));
    }
    else {
        chOpened[chId + 1] = false;
        channel.setButtonText(chButtons, chId, false, chNames);
        clearWindowMapByChannel(chId);

        setStatus("通道 " ++ string.format("%02d", chId + 1) ++ " 关闭失败，已按原网页状态模型重置按钮");
    }
}

toggleChannel = function(chId){
    var idx = chId + 1;

    if(chOpened[idx]) {
        closeChannel(chId);
    }
    else {
        openChannel(chId);
    }
}

ptz = function(cmd, stop){
    if(!wbReady) return;

    logger.call("JS ptz(" ++ tostring(cmd) ++ "," ++ tostring(stop) ++ ")");
    var r = callJs("ptz", cmd, stop);
    logger.ret("ptz=" ++ tostring(r));
}

activeXMenu = function(funcName, label, needLogin){
    if(!wbReady) {
        logger.info("ActiveX 尚未加载，先加载控件再打开菜单：" ++ label);
        setStatus("ActiveX 尚未加载，正在加载控件，请稍后重试：" ++ label);
        loadMiniHtml(false);
        return;
    }

    if(needLogin && !isLoggedIn) {
        logger.info(label ++ " 需要登录，先执行登录");
        setStatus(label ++ "需要先连接设备");
        pendingAutoOpenAll = false;
        loginDevice();
        return;
    }

    logger.call("JS " ++ funcName ++ "()");
    var r = callJs(funcName);
    logger.ret(funcName ++ "=" ++ tostring(r));

    setStatus("已打开：" ++ label);
}

showSettingDialog = function(){
    logger.info("打开设置对话框");
    var re = mainForm.loadForm("\dlg\setting.aardio").doModal();
    if(re == 1) {
        loadConfig();
        logger.info("设置已更新 level=" ++ config.log.level ++ " fileEnabled=" ++ tostring(config.log.fileEnabled));
        if(hasFullConfig()) {
            logoutDevice();
            mainForm.setTimeout(
                function(){
                    autoLoginAndOpenAll();
                },
                500
            );
        }
    }
}

openWebVersion = function(){
    if(webDlg !== null) {
        logger.info("内嵌 Web 版窗口已打开，忽略重复打开请求");
        setStatus("内嵌 Web 版窗口已打开");
        return;
    }

    logger.info("打开内嵌 Web 版窗口");
    unloadMainActiveX();

    webDlg = mainForm.loadForm("\dlg\web.aardio");
    webDlg.onClose = function(){
        logger.info("内嵌 Web 版窗口已关闭");
        webDlg = null;
        setStatus("内嵌 Web 版已关闭，可重新连接主界面");
    }
    webDlg.show();
}

openDeviceInBrowser = function(){
    loadConfig();

    var ip = cfg.ip;
    if(ip === null || ip == "") {
        ip = "192.168.0.5";
    }

    logger.info("在系统浏览器中打开设备页面 ip=" ++ ip);
    process.execute("http://" ++ ip);
}

// 初始化通道按钮数组
chButtons = {
    mainForm.btnCh01;
    mainForm.btnCh02;
    mainForm.btnCh03;
    mainForm.btnCh04;
    mainForm.btnCh05;
    mainForm.btnCh06;
    mainForm.btnCh07;
    mainForm.btnCh08;
}

loadConfig();
channel.loadNames(chNames);

for(i=1;8;1){
    chOpened[i] = false;
    channel.setButtonText(chButtons, i - 1, false, chNames);
}

// 事件绑定
mainForm.btnSetting.oncommand = function(){
    showSettingDialog();
}

mainForm.btnLogin.oncommand = function(){
    autoLoginAndOpenAll();
}

mainForm.btnLogout.oncommand = function(){
    logoutDevice();
}

mainForm.btnOpenAll.oncommand = function(){
    openAllChannels();
}

mainForm.btnCloseAll.oncommand = function(){
    closeAllChannels();
}

mainForm.btnSysConfig.oncommand = function(){
    activeXMenu("showDeviceConfig", "系统设置", 1);
}

mainForm.btnPlayback.oncommand = function(){
    activeXMenu("showPlayback", "录像查询", 1);
}

mainForm.btnAlarm.oncommand = function(){
    activeXMenu("showAlarm", "警报设置", 1);
}

mainForm.btnAbout.oncommand = function(){
    activeXMenu("showAbout", "关于", 0);
}

mainForm.btnWeb.oncommand = function(){
    openWebVersion();
}

mainForm.btnBrowser.oncommand = function(){
    openDeviceInBrowser();
}

mainForm.btnCh01.oncommand = function(){ toggleChannel(0); }
mainForm.btnCh02.oncommand = function(){ toggleChannel(1); }
mainForm.btnCh03.oncommand = function(){ toggleChannel(2); }
mainForm.btnCh04.oncommand = function(){ toggleChannel(3); }
mainForm.btnCh05.oncommand = function(){ toggleChannel(4); }
mainForm.btnCh06.oncommand = function(){ toggleChannel(5); }
mainForm.btnCh07.oncommand = function(){ toggleChannel(6); }
mainForm.btnCh08.oncommand = function(){ toggleChannel(7); }

mainForm.btnUp.onMouseDown = function(){ ptz(0, 0); }
mainForm.btnUp.onMouseUp = function(){ ptz(0, 1); }

mainForm.btnDown.onMouseDown = function(){ ptz(1, 0); }
mainForm.btnDown.onMouseUp = function(){ ptz(1, 1); }

mainForm.btnLeft.onMouseDown = function(){ ptz(2, 0); }
mainForm.btnLeft.onMouseUp = function(){ ptz(2, 1); }

mainForm.btnRight.onMouseDown = function(){ ptz(3, 0); }
mainForm.btnRight.onMouseUp = function(){ ptz(3, 1); }

mainForm.onClose = function(){
    logoutDevice();
}

mainForm.center();
mainForm.show();

mainForm.setTimeout(
    function(){
        if(hasFullConfig()) {
            autoLoginAndOpenAll();
        }
        else {
            setStatus("未设置密码，请点击“设置”");
        }
    },
    500
);

return win.loopMessage();
