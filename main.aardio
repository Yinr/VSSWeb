        logMsg("JS AboutBox called");
        return true;
    }catch(e){
        logMsg("JS AboutBox error=" + e.message);
        return false;
    }
}

function logoutDevice(){
    try{ ocx.DisConnectAllChannel(); }catch(e){}
    try{ ocx.LogoutDevice(); }catch(e){}
    try{ ocx.CloseLocalPlay(); }catch(e){}
}
</script>

<script language="javascript" for="ocx" event="StateChanged(ci,ps,wid)">
    try{
        window.external.StateChanged(ci,ps,wid);
    }catch(e){}
</script>

<script language="javascript" for="ocx" event="ReturnWindInfo(wid,cid,ps,sit)">
    try{
        window.external.ReturnWindInfo(wid,cid,ps,sit);
    }catch(e){}
</script>

<script language="javascript" for="ocx" event="DeviceDisconnected(ip,pt)">
