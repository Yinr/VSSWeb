        window.external.DeviceChanged(strDevIp,lPort,lType);
    }catch(e){}
</script>

</body>
</html>
*/;

    html = string.replace(html, "__BASE_URL__", baseUrl);
    return html;
}

setupExternal = function(){
    wb.external = {
        GetIp = function(){
            return cfg.ip;
        };

        GetUsername = function(){
            return cfg.username;
        };

        GetPassword = function(){
            return cfg.password;
        };

        Log = function(msg){
            logger.js(toText(msg));
        };

        LoginResult = function(ret){
            logger.callback("LoginResult=" ++ toText(ret));

            if(isTrueValue(ret) == 1) {
                isLoggedIn = 1;
                setStatus("登录成功：" ++ cfg.ip);

                if(pendingAutoOpenAll == 1) {
                    pendingAutoOpenAll = 0;

                    mainForm.setTimeout(
                        function(){
                            openAllChannels();
                        },
                        1000
                    );
                }
            }
            else {
                isLoggedIn = 0;
                pendingAutoOpenAll = 0;
                setStatus("登录失败：ActiveX 返回 " ++ toText(ret));
            }
        };

        OpenAllResult = function(ret){
            logger.callback("OpenAllResult=" ++ toText(ret));

            if(isTrueValue(ret) == 1) {
                setStatus("已请求打开全部通道");
            }
            else {
                setStatus("打开全部通道失败：" ++ toText(ret));
            }
        };

        CloseAllResult = function(ret){
            logger.callback("CloseAllResult=" ++ toText(ret));

            if(isTrueValue(ret) == 1) {
                clearAllChannelState();
                currentWid = null;
                winMap = {};
                winState = {};
                setStatus("已请求关闭全部通道");
            }
            else {
                setStatus("关闭全部通道失败：" ++ toText(ret));
            }
        };

        StateChanged = function(ci, ps, wid){
            logger.event(
                "StateChanged"
                ++ " ci=" ++ toText(ci)
                ++ " ch=" ++ (ci >= 0 && ci <= 7 ? pad2(ci + 1) : "-")
                ++ " ps=" ++ toText(ps)
                ++ " wid=" ++ toText(wid)
            );

            if(ci == -1 || ci == 32) {
                if(ps == 3 || ps == 5) {
                    setStatus("当前窗口进入回放/播放控制状态 ps=" ++ toText(ps));
                }
                else {
                    setStatus("特殊播放状态 ci=" ++ toText(ci) ++ " ps=" ++ toText(ps));
                }

                return;
            }

            if(ci >= 0 && ci <= 7) {
                if(ps == 1 || ps == 2) {
                    chOpened[ci + 1] = 1;
                    setChButtonText(ci, 1);
                    setStatus("通道 " ++ pad2(ci + 1) ++ " 正在播放 ps=" ++ toText(ps));
                }
                elseif(ps == 0) {
                    chOpened[ci + 1] = 0;
                    setChButtonText(ci, 0);
                    clearWindowMapByChannel(ci);
                    setStatus("通道 " ++ pad2(ci + 1) ++ " 已关闭");
                }
                elseif(ps == 3) {
                    chOpened[ci + 1] = 0;
                    setChButtonText(ci, 0);
                    clearWindowMapByChannel(ci);
                    setStatus("通道 " ++ pad2(ci + 1) ++ " 进入非实时预览状态 ps=3，已重置按钮");
                }
                else {
                    setStatus("通道 " ++ pad2(ci + 1) ++ " 未处理状态 ps=" ++ toText(ps));
                }
            }
            else {
                setStatus("通道状态变化 ci=" ++ toText(ci) ++ " ps=" ++ toText(ps));
            }
        };

        ReturnWindInfo = function(wid, cid, ps, sit){
            logger.event(
                "ReturnWindInfo"
                ++ " wid=" ++ toText(wid)
                ++ " cid=" ++ toText(cid)
                ++ " ch=" ++ (cid >= 0 && cid <= 7 ? pad2(cid + 1) : "-")
                ++ " ps=" ++ toText(ps)
                ++ " sit=" ++ toText(sit)
            );

            currentWid = wid;

            if(wid !== null) {
                var key = "w" ++ toText(wid);

                if(ps == 1 || ps == 2) {
                    winMap[key] = cid;
                    winState[key] = ps;
                }
                elseif(ps == 0) {
                    winMap[key] = -1;
                    winState[key] = ps;
                }
                elseif(ps == 4 || ps == 5) {
                    winState[key] = ps;
                }
                else {
                    winMap[key] = cid;
                    winState[key] = ps;
                }
            }

            if(ps == 4 || ps == 5) {
                setStatus("当前窗口处于录像/回放状态 ps=" ++ toText(ps));
            }
            else {
                setStatus(
                    "窗口信息 wid=" ++ toText(wid)
                    ++ " cid=" ++ toText(cid)
                    ++ " ps=" ++ toText(ps)
                );
            }
        };

        DeviceDisconnected = function(ip, pt){
            logger.event("DeviceDisconnected ip=" ++ toText(ip) ++ " pt=" ++ toText(pt));

            isLoggedIn = 0;
            clearAllChannelState();
            currentWid = null;
            winMap = {};
            winState = {};
            setStatus("设备断开：" ++ toText(ip));
        };

        DeviceChanged = function(strDevIp, lPort, lType){
            logger.event(
                "DeviceChanged"
                ++ " ip=" ++ toText(strDevIp)
                ++ " port=" ++ toText(lPort)
                ++ " type=" ++ toText(lType)
            );

            setStatus(
                "设备变化 ip=" ++ toText(strDevIp)
                ++ " port=" ++ toText(lPort)
                ++ " type=" ++ toText(lType)
            );
        };
    }
}

loadMiniHtml = function(autoConnect){
    loadConfig();
    loadChannelNames();

    wbReady = 0;
    isLoggedIn = 0;
    pendingAutoOpenAll = 0;
    currentWid = null;
    winMap = {};
    winState = {};
    clearAllChannelState();

    logger.clear();

    log("==============================================");
    log("监控程序启动");
    log("配置文件：" ++ config.path);
    log("日志文件：" ++ logger.path);
    log("ip=" ++ cfg.ip);
    log("username=" ++ cfg.username);
    log("password=" ++ (cfg.password == "" ? "<空>" : "<已设置>"));
    log("==============================================");

    if(wb === null) {
        wb = web.form(mainForm.videoHost);
        wb.silent = true;
        setupExternal();
    }

    wb.write(makeHtml());
    setStatus("已加载 ActiveX，默认 4 窗格");

    mainForm.setTimeout(
        function(){
            wbReady = 1;
            setStatus("ActiveX 已准备好");

            logger.call("JS ping()");
            var pingRet = callJs("ping");
            logger.ret("ping=" ++ toText(pingRet));

            if(autoConnect == 1) {
                autoLoginAndOpenAll();
            }
        },
        2000
    );
}

loginDevice = function(){
    loadConfig();

    if(wbReady != 1) {
        setStatus("ActiveX 尚未准备好");
        return 0;
    }

    if(hasFullConfig() != 1) {
        setStatus("未设置完整连接信息，请点击“设置”");
        return 0;
    }

    setStatus("正在连接：" ++ cfg.ip);

    logger.call("JS loginFromExternal()");
    var r = callJs("loginFromExternal");
    logger.ret("loginFromExternal=" ++ toText(r));

    return 1;
}

autoLoginAndOpenAll = function(){
    pendingAutoOpenAll = 1;
    loginDevice();
}

logoutDevice = function(){
    logger.call("JS logoutDevice()");

    try {
        var r = callJs("logoutDevice");
        logger.ret("logoutDevice=" ++ toText(r));
    }
    catch(e) {
    }

    isLoggedIn = 0;
    pendingAutoOpenAll = 0;
    clearAllChannelState();
    currentWid = null;
    winMap = {};
    winState = {};
    setStatus("已断开");
}

openAllChannels = function(){
    if(wbReady != 1) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    if(isLoggedIn != 1) {
        pendingAutoOpenAll = 1;
        loginDevice();
        return;
    }

    logger.call("JS openAll()");
    var r = callJs("openAll");
    logger.ret("openAll=" ++ toText(r));
}

closeAllChannels = function(){
    if(wbReady != 1) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    logger.call("JS closeAll()");
    var r = callJs("closeAll");
    logger.ret("closeAll=" ++ toText(r));
}

openChannel = function(chId){
    if(wbReady != 1) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    if(isLoggedIn != 1) {
        pendingAutoOpenAll = 0;
        loginDevice();
        return;
    }

    logger.call("JS openChannel(" ++ tostring(chId) ++ ")");
    var r = callJs("openChannel", chId);
    logger.ret("openChannel=" ++ toText(r));

    setStatus("已请求打开通道 " ++ pad2(chId + 1));
}

closeChannel = function(chId){
    if(wbReady != 1) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    logger.call("JS closeChannel(" ++ tostring(chId) ++ ")");
    var r = callJs("closeChannel", chId);
    logger.ret("closeChannel=" ++ toText(r));

    if(isTrueValue(r) == 1) {
        setStatus("已请求关闭通道 " ++ pad2(chId + 1));
    }
    else {
        chOpened[chId + 1] = 0;
        setChButtonText(chId, 0);
        clearWindowMapByChannel(chId);

        setStatus("通道 " ++ pad2(chId + 1) ++ " 关闭失败，已按原网页状态模型重置按钮");
    }
}

toggleChannel = function(chId){
    var idx = chId + 1;

    if(chOpened[idx] == 1) {
        closeChannel(chId);
    }
    else {
        openChannel(chId);
    }
}

ptz = function(cmd, stop){
    if(wbReady != 1) return;

    logger.call("JS ptz(" ++ tostring(cmd) ++ "," ++ tostring(stop) ++ ")");
    var r = callJs("ptz", cmd, stop);
    logger.ret("ptz=" ++ toText(r));
}

activeXMenu = function(funcName, label, needLogin){
    if(wbReady != 1) {
        setStatus("ActiveX 尚未准备好");
        return;
    }

    if(needLogin == 1 && isLoggedIn != 1) {
        setStatus(label ++ "需要先连接设备");
        pendingAutoOpenAll = 0;
        loginDevice();
        return;
    }

    logger.call("JS " ++ funcName ++ "()");
    var r = callJs(funcName);
    logger.ret(funcName ++ "=" ++ toText(r));

    setStatus("已打开：" ++ label);
}

showSettingDialog = function(){
    loadConfig();

    var dlg = win.form(
        parent = mainForm;
        text = "连接设置";
        left = -1;
        top = -1;
        right = 420;
        bottom = 230;
        max = false;
        min = false;
    );

    dlg.add(
        lblIp = {cls = "static"; text = "连接地址"; left = 30; top = 30; right = 110; bottom = 55;};
        editIp = {cls = "edit"; text = cfg.ip; left = 120; top = 28; right = 380; bottom = 56; edge = 1;};
        lblUser = { cls = "static"; text = "用户名"; left = 30; top = 75; right = 110; bottom = 100;};
        editUser = { cls = "edit"; text = cfg.username; left = 120; top = 73; right = 380; bottom = 101; edge = 1;};
        lblPass = {cls = "static"; text = "密码"; left = 30; top = 120; right = 110; bottom = 145;};
        editPass = {cls = "edit"; text = cfg.password; left = 120; top = 118; right = 380; bottom = 146; edge = 1; password = 1;};
        btnSave = {cls = "button"; text = "保存"; left = 120; top = 170; right = 230; bottom = 205;};
        btnCancel = {cls = "button"; text = "取消"; left = 270; top = 170; right = 380; bottom = 205;}
    );

    dlg.btnSave.oncommand = function(){
        cfg.ip = dlg.editIp.text;
        cfg.username = dlg.editUser.text;
        cfg.password = dlg.editPass.text;

        if(cfg.ip == "") {
            cfg.ip = "192.168.0.5";
        }

        if(cfg.username == "") {
            cfg.username = "admin";
        }

        saveConfig();
        dlg.close();

        setStatus("设置已保存，正在重新加载控件");

        logoutDevice();

        mainForm.setTimeout(
            function(){
                loadMiniHtml(1);
            },
            500
        );
    }

    dlg.btnCancel.oncommand = function(){
        dlg.close();
    }

    dlg.show();
}

// 初始化通道按钮数组
chButtons = {
    mainForm.btnCh01;
    mainForm.btnCh02;
    mainForm.btnCh03;
    mainForm.btnCh04;
    mainForm.btnCh05;
    mainForm.btnCh06;
    mainForm.btnCh07;
    mainForm.btnCh08;
}

loadConfig();
loadChannelNames();

for(i=1;8;1){
    chOpened[i] = 0;
    setChButtonText(i - 1, 0);
}

// 事件绑定
mainForm.btnSetting.oncommand = function(){
    showSettingDialog();
}

mainForm.btnLogin.oncommand = function(){
    autoLoginAndOpenAll();
}

mainForm.btnLogout.oncommand = function(){
    logoutDevice();
}

mainForm.btnOpenAll.oncommand = function(){
    openAllChannels();
}

mainForm.btnCloseAll.oncommand = function(){
    closeAllChannels();
}

mainForm.btnSysConfig.oncommand = function(){
    activeXMenu("showDeviceConfig", "系统设置", 1);
}

mainForm.btnPlayback.oncommand = function(){
    activeXMenu("showPlayback", "录像查询", 1);
}

mainForm.btnAlarm.oncommand = function(){
    activeXMenu("showAlarm", "警报设置", 1);
}

mainForm.btnAbout.oncommand = function(){
    activeXMenu("showAbout", "关于", 0);
}

mainForm.btnCh01.oncommand = function(){ toggleChannel(0); }
mainForm.btnCh02.oncommand = function(){ toggleChannel(1); }
mainForm.btnCh03.oncommand = function(){ toggleChannel(2); }
mainForm.btnCh04.oncommand = function(){ toggleChannel(3); }
mainForm.btnCh05.oncommand = function(){ toggleChannel(4); }
mainForm.btnCh06.oncommand = function(){ toggleChannel(5); }
mainForm.btnCh07.oncommand = function(){ toggleChannel(6); }
mainForm.btnCh08.oncommand = function(){ toggleChannel(7); }

mainForm.btnUp.onMouseDown = function(){ ptz(0, 0); }
mainForm.btnUp.onMouseUp = function(){ ptz(0, 1); }

mainForm.btnDown.onMouseDown = function(){ ptz(1, 0); }
mainForm.btnDown.onMouseUp = function(){ ptz(1, 1); }

mainForm.btnLeft.onMouseDown = function(){ ptz(2, 0); }
mainForm.btnLeft.onMouseUp = function(){ ptz(2, 1); }

mainForm.btnRight.onMouseDown = function(){ ptz(3, 0); }
mainForm.btnRight.onMouseUp = function(){ ptz(3, 1); }

mainForm.onClose = function(){
    logoutDevice();
}

mainForm.center();
mainForm.show();

mainForm.setTimeout(
    function(){
        if(hasFullConfig() == 1) {
            loadMiniHtml(1);
        }
        else {
            loadMiniHtml(0);
            setStatus("未设置密码，请点击“设置”");
        }
    },
    500
);

return win.loopMessage();
