btnCh01={cls="button";text="打开 01";left=920;top=210;right=1035;bottom=245;dr=1;z=12};
btnCh02={cls="button";text="打开 02";left=1050;top=210;right=1165;bottom=245;dr=1;z=14};
btnCh03={cls="button";text="打开 03";left=920;top=252;right=1035;bottom=287;dr=1;z=4};
btnCh04={cls="button";text="打开 04";left=1050;top=252;right=1165;bottom=287;dr=1;z=9};
btnCh05={cls="button";text="打开 05";left=920;top=294;right=1035;bottom=329;dr=1;z=21};
