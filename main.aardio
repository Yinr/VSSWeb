import fsys.update.simpleMain;
if( fsys.update.simpleMain(
	"VSSWeb",
	"https://vssweb.lolicon.in/version.txt", /*网址也可以改用目录名，并使用服务端代码动态返回version.txt*/
	"/download/update-files", /*绿色软件建议改为 io.appData("/软件厂商名/软件名字/update-files") */
	function(version,description,status){
		if(status == "ready"){
			import fsys.version;
			var verInfo = fsys.version.getInfo(io._exepath);
			var currentVersion = verInfo ? tostring(verInfo.productVersion) : "未知版本";

			var msg = '发现新版本！\n\n当前版本：' ++ currentVersion ++ '\n最新版本：' ++ version;
			if(description && description != ""){
				msg = msg ++ '\n\n更新内容：\n' ++ description;
			}
			msg = msg ++ '\n\n建议立即重启应用以完成更新，或在下次启动时自动更新。';
			win.msgbox(msg, "更新提示", "info", mainForm);
		}
	} )){
	return 0; //必须退出 main.aardio 以启动更新
}

web.form.emulation(11001);

// 日志初始化
logger.init(mainForm.editLog);

log = function(msg){
    logger.write(msg);
}

var cfg = {
    ip = "";
    username = "";
    password = "";
}

var wb = null;
var wbReady = 0;
var isLoggedIn = 0;
var pendingAutoOpenAll = 0;

var chButtons = {};
var chOpened = {};
var chNames = {};
var currentWid = null;
var winMap = {};
var winState = {};

toText = function(v){
    if(v === null) {
        return "<null>";
    }

    return tostring(v);
}

pad2 = function(n){
    return string.format("%02d", n);
}

isTrueValue = function(v){
    var s = string.lower(toText(v));

    if(s == "true") return 1;
    if(s == "1") return 1;

    return 0;
}

setStatus = function(msg){
    logger.status(msg);

    var s = "状态：" ++ msg;

    if(currentWid !== null) {
        s = s ++ '\r\n当前窗口：' ++ toText(currentWid);

        var key = "w" ++ toText(currentWid);
        var cid = winMap[key];

        if(cid !== null && cid >= 0) {
            s = s ++ " / 通道 " ++ pad2(cid + 1);
        }
        else {
            s = s ++ " / 空";
        }
    }

    mainForm.statusText.text = s;
}

loadConfig = function(){
    config.loadDevice();

    cfg.ip = config.device.ip;
    if(cfg.ip === null || cfg.ip == "") {
        cfg.ip = "192.168.0.5";
    }

    cfg.username = config.device.username;
    if(cfg.username === null || cfg.username == "") {
        cfg.username = "admin";
    }

    cfg.password = config.device.password;
    if(cfg.password === null) {
        cfg.password = "";
    }
}

saveConfig = function(){
    config.device.ip = cfg.ip;
    config.device.username = cfg.username;
    config.device.password = cfg.password;

    config.saveDevice();
}

loadChannelNames = function(){
    config.loadChannelNames();

    for(i=1;8;1){
        var key = "ch" ++ pad2(i);
        var name = config.channelNames[key];

        if(name === null || name == "") {
            name = pad2(i);
        }

        chNames[i] = name;
    }
}

hasFullConfig = function(){
    if(cfg.ip === null || cfg.ip == "") return 0;
    if(cfg.username === null || cfg.username == "") return 0;
    if(cfg.password === null || cfg.password == "") return 0;

    return 1;
}

setChButtonText = function(chId, opened){
    var idx = chId + 1;
    var name = chNames[idx];

    if(name === null || name == "") {
        name = pad2(idx);
    }

    if(opened == 1) {
        chButtons[idx].text = "关闭 " ++ name;
    }
    else {
        chButtons[idx].text = "打开 " ++ name;
    }
}

clearAllChannelState = function(){
    for(i=1;8;1){
        chOpened[i] = 0;
        setChButtonText(i - 1, 0);
    }
}

clearWindowMapByChannel = function(chId){
    for(w=0;15;1){
        var key = "w" ++ tostring(w);

        if(winMap[key] === chId) {
            winMap[key] = -1;
            winState[key] = 0;
        }
    }
}

callJs = function(funcName, a, b){
    if(wb === null) {
        setStatus("浏览器控件尚未创建");
        return null;
    }

    var script = "";

    if(funcName == "ping") {
        script = "ping();";
    }
    elseif(funcName == "loginFromExternal") {
        script = "loginFromExternal();";
    }
    elseif(funcName == "openAll") {
        script = "openAll();";
    }
    elseif(funcName == "closeAll") {
        script = "closeAll();";
    }
    elseif(funcName == "openChannel") {
        script = "openChannel(" ++ tostring(a) ++ ");";
    }
    elseif(funcName == "closeChannel") {
        script = "closeChannel(" ++ tostring(a) ++ ");";
    }
    elseif(funcName == "ptz") {
        script = "ptz(" ++ tostring(a) ++ "," ++ tostring(b) ++ ");";
    }
    elseif(funcName == "showDeviceConfig") {
        script = "showDeviceConfig();";
    }
    elseif(funcName == "showPlayback") {
        script = "showPlayback();";
    }
    elseif(funcName == "showAlarm") {
        script = "showAlarm();";
    }
    elseif(funcName == "showAbout") {
        script = "showAbout();";
    }
    elseif(funcName == "logoutDevice") {
        script = "logoutDevice();";
    }
    else {
        logger.error("未知 JS 函数：" ++ funcName);
        return null;
    }

    try {
        log("[SCRIPT] " ++ script);
        return wb.doScript(script);
    }
    catch(e) {
        logger.error("doScript 调用失败：" ++ funcName ++ " / " ++ tostring(e));
        setStatus("调用 JS 失败：" ++ funcName);
        return null;
    }
}

makeHtml = function(){
    var baseUrl = "http://" ++ cfg.ip ++ "/";

    var html = /*
<!doctype html>
<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=EmulateIE11">
