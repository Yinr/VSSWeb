<script type="text/javascript">
function logMsg(msg){
    try{
        window.external.Log(msg);
    }catch(e){}
}

function ping(){
    logMsg("JS ping called");
    return "pong";
}

function loginFromExternal(){
    try{
        var ip = window.external.GetIp();
        var username = window.external.GetUsername();
        var password = window.external.GetPassword();

        logMsg("JS loginFromExternal ip=" + ip + " username=" + username);

        var r = ocx.LoginDeviceEx(ip, 0, username, password, 0);

        logMsg("JS LoginDeviceEx ret=" + r);

        try{
            window.external.LoginResult(r);
        }catch(e){}

        return r;
    }catch(e){
        logMsg("JS LoginDeviceEx error=" + e.message);

        try{
            window.external.LoginResult(false);
        }catch(ex){}

        return false;
    }
}

function openAll(){
    try{
        var r = ocx.ConnectAllChannle();

        logMsg("JS ConnectAllChannle ret=" + r);

        try{
            window.external.OpenAllResult(r);
        }catch(e){}

        return r;
    }catch(e){
        logMsg("JS ConnectAllChannle error=" + e.message);

        try{
            window.external.OpenAllResult(false);
        }catch(ex){}

        return false;
    }
}

function closeAll(){
    try{
        var r = ocx.DisConnectAllChannel();

        logMsg("JS DisConnectAllChannel ret=" + r);

        try{
            window.external.CloseAllResult(r);
        }catch(e){}

        return r;
    }catch(e){
        logMsg("JS DisConnectAllChannel error=" + e.message);

        try{
            window.external.CloseAllResult(false);
        }catch(ex){}

        return false;
    }
}

function openChannel(ch){
    try{
        var r = ocx.ConnectRealVideo(ch, 1);

        logMsg("JS ConnectRealVideo(" + ch + ",1) ret=" + r);

        return r;
    }catch(e){
        logMsg("JS ConnectRealVideo error=" + e.message);
        return false;
    }
}

function closeChannel(ch){
    try{
        var r = ocx.DisConnectRealVideo(ch);

        logMsg("JS DisConnectRealVideo(" + ch + ") ret=" + r);

        return r;
    }catch(e){
        logMsg("JS DisConnectRealVideo error=" + e.message);
        return false;
    }
}

function ptz(cmd, stop){
    try{
        var r = ocx.ControlPtz(cmd, 0, 5, 0, stop);
        return r;
    }catch(e){
        logMsg("JS ControlPtz error=" + e.message);
        return false;
    }
}

function showDeviceConfig(){
    try{
        var r = ocx.ShowDeviceConfig();
        logMsg("JS ShowDeviceConfig ret=" + r);
        return r;
    }catch(e){
        logMsg("JS ShowDeviceConfig error=" + e.message);
